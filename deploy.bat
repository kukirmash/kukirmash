@echo off
:: Включаем поддержку UTF-8 для корректного отображения русского языка и эмодзи
chcp 65001 >nul
setlocal enabledelayedexpansion

:: Переходим в директорию, где лежит сам скрипт
cd /d "%~dp0"

:: ==========================================
:: ШАГ 0: ПРОВЕРКА DOCKER
:: ==========================================
docker info >nul 2>&1
if %errorlevel% neq 0 (
    echo ⏳ Docker не запущен. Пытаюсь запустить Docker Desktop...
    
    :: Запускаем Docker Desktop (указан стандартный путь установки в Windows)
    start "" "C:\Program Files\Docker\Docker\Docker Desktop.exe"
    
    :: Ждем 10 секунд, так как в Windows Docker может запускаться немного дольше
    timeout /t 10 /nobreak >nul
    
    :: Проверяем еще раз
    docker info >nul 2>&1
    if !errorlevel! neq 0 (
        echo ❌ Не удалось запустить Docker. Пожалуйста, запусти Docker Desktop вручную.
        pause
        exit /b 1
    )
    echo ✅ Docker успешно запущен!
)

:: ==========================================
:: ШАГ 1: ОСТАНОВКА
:: ==========================================
echo 🐳 Останавливаем старые контейнеры...
docker compose down

:: ==========================================
:: ШАГ 2: СБОРКА ФРОНТЕНДА
:: ==========================================
echo 📦 Собираем React (Frontend)...
if not exist "kukirmash_frontend\" (
    echo ❌ Папка kukirmash_frontend не найдена!
    pause
    exit /b 1
)

cd kukirmash_frontend

:: Устанавливаем зависимости и собираем билд (используем call для npm)
call npm install
call npm run build

:: Возвращаемся обратно в корень
cd ..
echo ✅ Фронтенд успешно собран!

:: ==========================================
:: ШАГ 3: ЗАПУСК DOCKER COMPOSE
:: ==========================================
echo 🚀 Собираем и запускаем проект...
docker compose up --build -d

if %errorlevel% equ 0 (
    echo =========================================
    echo ✅ УСПЕХ! Проект запущен в Docker.
    echo =========================================
) else (
    echo =========================================
    echo ❌ ОШИБКА! Проблема при запуске Docker Compose.
    echo =========================================
)

:: Оставляем окно открытым в конце, чтобы увидеть результат
pause